{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm prisma generate && pnpm build",
  "crons": [
    {
      "path": "/api/health",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/admin/users/lock-inactive",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/daily-notifications",
      "schedule": "0 22 * * *"
    }
  ]
}
