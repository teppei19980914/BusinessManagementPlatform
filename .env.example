# === ポート設定（既存環境と競合する場合に変更） ===
APP_PORT=3000
DB_PORT=5433

# === データベース設定 ===
DB_NAME=tasukiba
DB_USER=postgres
DB_PASSWORD=postgres

# ローカル開発用（Docker Compose）
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/tasukiba"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/tasukiba"

# Supabase 利用時（上記をコメントアウトし以下を使用）
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# === アプリケーション設定 ===
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET= # openssl rand -base64 32 で生成

# === メール設定 ===
# console: メール送信せずコンソール出力（開発・試験運用向け）
# brevo:   Brevo API 経由でメール送信（https://www.brevo.com/ — 無料: 300通/日）
# resend:  Resend API 経由でメール送信（https://resend.com/）
# smtp:    SMTP 直接送信（外部配布向け）
MAIL_PROVIDER=console

# 送信元アドレス（Brevo / Resend 共通）
MAIL_FROM=noreply@example.com
# 送信元表示名（Brevo のみ使用）
MAIL_FROM_NAME=たすきば

# Brevo の場合（MAIL_PROVIDER=brevo に変更）★推奨
# https://app.brevo.com/settings/keys/api で API キーを取得
# 送信元メールアドレスは Brevo ダッシュボードで事前検証が必要
# BREVO_API_KEY=xkeysib-xxxxxxxxxx

# Resend の場合（MAIL_PROVIDER=resend に変更）
# https://resend.com/api-keys で API キーを取得
# ※ ドメイン未検証の場合、オーナーメール以外への送信不可
# RESEND_API_KEY=re_xxxxxxxxxx

# SMTP の場合（MAIL_PROVIDER=smtp に変更）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=

# === 初期管理者（シード用） ===
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD= # 10文字以上、英大文字・英小文字・数字・記号のうち3種以上

# === オプション ===
SEARCH_PROVIDER=pg_trgm
ENABLE_OPERATION_TRACE=false

# === Cron バッチ認証 ===
CRON_SECRET=
