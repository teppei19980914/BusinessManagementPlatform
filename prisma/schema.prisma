model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  action      String   @db.VarChar(50) // CREATE | UPDATE | DELETE
  entityType  String   @map("entity_type") @db.VarChar(50)
  entityId    String   @map("entity_id") @db.Uuid
  beforeValue Json?    @map("before_value") @db.JsonB
  afterValue  Json?    @map("after_value") @db.JsonB
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([entityType, entityId], map: "idx_audit_entity")
  @@index([userId, createdAt(sort: Desc)], map: "idx_audit_user")
  @@index([createdAt(sort: Desc)], map: "idx_audit_date")
  @@map("audit_logs")
}

model AuthEventLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType String   @map("event_type") @db.VarChar(30)
  userId    String?  @map("user_id") @db.Uuid
  email     String?  @db.VarChar(255)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  detail    Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)], map: "idx_auth_events_user")
  @@index([eventType, createdAt(sort: Desc)], map: "idx_auth_events_type")
  @@map("auth_event_logs")
}

/// PR #115 (2026-04-24): 内部エラー / クライアントエラーを蓄積するテーブル。
///
/// 設計思想 (DESIGN.md §9.8.5):
///   - ブラウザの Console や Server console に機密情報 (スタック、設定、SQL 内部情報等) を出さず、
///     必ず本テーブルに保存してから、ユーザには固定文言「内部エラーが発生しました」を返す。
///   - AuditLog は userId NOT NULL で pre-auth エラーを記録できないため、
///     AuthEventLog と同じ「nullable userId + JSON detail」パターンで分離した姉妹テーブル。
///   - severity で重要度を分類 (info / warn / error / fatal)。
///   - source で発生箇所カテゴリを記録 (server / client / cron 等)。
///   - context に IP / request path / 任意メタデータを JSON で持たせる。
model SystemErrorLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // PR #2: tenant 配属 (DEFAULT default-tenant)。pre-auth エラーは default-tenant に集約。
  tenantId  String   @default(dbgenerated("'00000000-0000-0000-0000-000000000001'::uuid")) @map("tenant_id") @db.Uuid
  severity  String   @db.VarChar(10) // 'info' | 'warn' | 'error' | 'fatal'
  source    String   @db.VarChar(30) // 'server' | 'client' | 'cron' | 'mail' | etc.
  message   String   @db.Text
  stack     String?  @db.Text
  userId    String?  @map("user_id") @db.Uuid
  requestId String?  @map("request_id") @db.VarChar(64)
  context   Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user   User?  @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([severity, createdAt(sort: Desc)], map: "idx_system_errors_severity")
  @@index([source, createdAt(sort: Desc)], map: "idx_system_errors_source")
  @@index([userId, createdAt(sort: Desc)], map: "idx_system_errors_user")
  @@index([createdAt(sort: Desc)], map: "idx_system_errors_date")
  @@index([tenantId, createdAt(sort: Desc)], map: "idx_system_errors_tenant")
  @@map("system_error_logs")
}

model RoleChangeLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  changedBy    String   @map("changed_by") @db.Uuid
  targetUserId String   @map("target_user_id") @db.Uuid
  changeType   String   @map("change_type") @db.VarChar(20) // system_role | project_role
  projectId    String?  @map("project_id") @db.Uuid
  beforeRole   String?  @map("before_role") @db.VarChar(30)
  afterRole    String   @map("after_role") @db.VarChar(30)
  reason       String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  changer    User @relation("RoleChanger", fields: [changedBy], references: [id])
  targetUser User @relation("RoleTarget", fields: [targetUserId], references: [id])

  @@map("role_change_logs")
}

/// 添付リンク (PR #64 Phase 1): 実ファイルは保持せず、外部ストレージの URL のみを格納する
/// ポリモーフィック関連 (entityType + entityId) で 6 種のエンティティと連携する:
///   project / task / estimate / risk / retrospective / knowledge
/// slot によって「単数」スロット (primary / source 等) と「複数」スロット (general) を
/// 同一テーブルで扱う — 単数制約は UI/サービス層で enforce する (DB は複数行を許容)。
/// 容量最適化のため 1 レコードあたり ~400B 以内に抑え、Supabase Free (DB 500MB) の
/// 長期運用に耐える設計 (DESIGN.md §21.2 DRY 原則に沿って共通テーブル化)。
model Attachment {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // PR #2: tenant 配属 (DEFAULT default-tenant)。親エンティティの tenantId と整合性をサービス層で担保。
  tenantId    String    @default(dbgenerated("'00000000-0000-0000-0000-000000000001'::uuid")) @map("tenant_id") @db.Uuid
  entityType  String    @map("entity_type") @db.VarChar(30)
  entityId    String    @map("entity_id") @db.Uuid
  slot        String    @default("general") @db.VarChar(30)
  displayName String    @map("display_name") @db.VarChar(200)
  url         String    @db.VarChar(2000)
  mimeHint    String?   @map("mime_hint") @db.VarChar(50)
  addedBy     String    @map("added_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  addedByUser User   @relation("AttachmentAddedBy", fields: [addedBy], references: [id])
  tenant      Tenant @relation(fields: [tenantId], references: [id])

  @@index([entityType, entityId], map: "idx_attachments_entity")
  @@index([entityType, entityId, slot], map: "idx_attachments_slot")
  @@index([tenantId], map: "idx_attachments_tenant")
  @@map("attachments")
}

/// コメント (PR #199): エンティティ編集 dialog 内のディスカッション用
/// ポリモーフィック関連 (entityType + entityId) で 7 種のエンティティと連携する:
///   issue / task / risk / retrospective / knowledge / customer / stakeholder
/// 既存の `RetrospectiveComment` テーブルは本 model に統合 (data migration あり)。
/// 認可方針:
///   - 投稿: 認証済ユーザは誰でも (project member 非メンバーも可、要件 Q4)
///   - 編集 / 削除: 投稿者本人 OR システム管理者 (要件 Q5)
/// 削除: soft-delete (`deletedAt`) — 監査要件 + 編集履歴保持目的
model Comment {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // PR #2: tenant 配属 (DEFAULT default-tenant)。親エンティティの tenantId と整合性をサービス層で担保。
  tenantId   String    @default(dbgenerated("'00000000-0000-0000-0000-000000000001'::uuid")) @map("tenant_id") @db.Uuid
  entityType String    @map("entity_type") @db.VarChar(30)
  entityId   String    @map("entity_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  content    String    @db.Text
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz

  user     User      @relation("CommentAuthor", fields: [userId], references: [id])
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  mentions Mention[]

  @@index([entityType, entityId, deletedAt], map: "idx_comments_entity")
  @@index([tenantId], map: "idx_comments_tenant")
  @@map("comments")
}

/// メンション (PR feat/comment-mentions): コメント本文中の `@username` / `@all` 等を
/// 構造化データとして保存し、通知配信のソースになる。
///
/// 設計方針:
///   - **kind の判別ユニオン**: 'user' (個別) / 'all' / 'project_member' / 'role_*' / 'assignee'
///     - kind='user' のみ targetUserId を持つ (個別指定)
///     - その他 (グループメンション) は targetUserId=null、配信時に動的に展開
///   - **コメント削除で cascade 物理削除** (`onDelete: Cascade`):
///     - コメントが消えたメンションは意味を持たないため、データ整合性のため自動削除
///   - **編集時の差分処理**: 旧 mention と新 mention を kind+targetUserId で diff し、
///     **追加分のみ通知** を生成 (Q2 採用)。削除分は何もしない。
model Mention {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // PR #2: tenant 配属 (DEFAULT default-tenant)。親 Comment の tenantId と整合性をサービス層で担保。
  tenantId     String   @default(dbgenerated("'00000000-0000-0000-0000-000000000001'::uuid")) @map("tenant_id") @db.Uuid
  commentId    String   @map("comment_id") @db.Uuid
  kind         String   @db.VarChar(40)
  targetUserId String?  @map("target_user_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  comment    Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  targetUser User?   @relation("MentionTarget", fields: [targetUserId], references: [id])
  tenant     Tenant  @relation(fields: [tenantId], references: [id])

  @@index([commentId], map: "idx_mentions_comment")
  @@index([tenantId], map: "idx_mentions_tenant")
  @@map("mentions")
}

/// 通知 (PR feat/notifications-mvp): アプリ内のベル UI に表示するエンドユーザ向けメッセージ。
/// 設計方針:
///   - **アプリ内通知のみ** (メール / push 通知は対象外)
///   - **polymorphic 連携** (entity_type + entity_id) で将来コメント mention 等に拡張可能
///   - **dedupeKey** で同じトリガが 1 日 1 回しか発火しないよう保証 (例: 同タスクの開始通知が
///     同日に複数回作られない)
///   - 既読 (readAt が NULL でない) かつ 30 日経過したものは cron で物理削除
///   - 受信者 (userId) は単一。複数ユーザに同時通知する場合は service 層でループ生成する
///
/// MVP の type:
///   - 'task_start_due' : ACT の予定開始日当日 (status='not_started')
///   - 'task_end_due'   : ACT の予定終了日当日 (status≠'completed')
/// 将来:
///   - 'comment_mention': コメント本文の @username で言及
model Notification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // PR #2: tenant 配属 (DEFAULT default-tenant)。User の tenantId と整合性をサービス層で担保。
  tenantId   String    @default(dbgenerated("'00000000-0000-0000-0000-000000000001'::uuid")) @map("tenant_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  type       String    @db.VarChar(40)
  entityType String    @map("entity_type") @db.VarChar(30)
  entityId   String    @map("entity_id") @db.Uuid
  title      String    @db.VarChar(200)
  link       String    @db.VarChar(500)
  /// 重複抑止用キー (例: `task_start_due:${taskId}:${YYYY-MM-DD}`)。
  /// UNIQUE 制約で 2 重生成を DB レベルで弾く (cron が時間内に 2 回呼ばれても安全)。
  dedupeKey  String    @map("dedupe_key") @db.VarChar(200)
  readAt     DateTime? @map("read_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user   User   @relation("NotificationRecipient", fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([dedupeKey], map: "idx_notifications_dedupe")
  @@index([userId, readAt, createdAt(sort: Desc)], map: "idx_notifications_user_unread")
  @@index([tenantId], map: "idx_notifications_tenant")
  @@map("notifications")
}

/// 個人メモ (PR #70): プロジェクトに紐付かない個人の知見・作業ノートを保存する。
/// visibility:
///   - 'private' (既定): 作成者本人のみ閲覧可、admin も含め他者不可視
///   - 'public' : 全ログインユーザが「全メモ」画面で閲覧可 (編集/削除は作成者のみ)
/// タグは持たせない (業務上の知見かどうかの判断は人間で行う方針、PR #70 要件より)。
/// 添付は PR #64 の attachments テーブルに entityType='memo' で紐付け可能。
model Memo {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // PR #2: tenant 配属 (DEFAULT default-tenant)。User の tenantId と整合性をサービス層で担保。
  tenantId   String    @default(dbgenerated("'00000000-0000-0000-0000-000000000001'::uuid")) @map("tenant_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  title      String    @db.VarChar(150)
  content    String    @db.Text
  visibility String    @default("private") @db.VarChar(20)
  // PR #4 (T-03 Phase 2): title + content を結合した text の embedding
  contentEmbedding Unsupported("vector(1024)")? @map("content_embedding")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz

  author User   @relation("MemoAuthor", fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  // 自分のメモ一覧 (MyMemos) での並び替えを効率化
  @@index([userId, createdAt(sort: Desc)], map: "idx_memos_user_recent")
  // 全メモ (公開メモ) 画面での並び替えを効率化
  @@index([visibility, createdAt(sort: Desc)], map: "idx_memos_visibility_recent")
  @@index([tenantId], map: "idx_memos_tenant")
  @@map("memos")
}

// ============================================================
// API Call Logs (PR #2 / T-03 提案エンジン v2)
// ============================================================
//
// 各 LLM / Embedding API 呼び出しの記録。**課金根拠データとして法的に重要**。
// withMeteredLLM ミドルウェアが成功時に必ず記録する。失敗時の記録方針は同 ミドルウェアに集約。
//
// `featureUnit` は「ユーザに見える 1 操作」と「内部処理」の対応関係を記録する識別子。
//   - 'new-project-suggestion'      新規プロジェクト作成時の提案 (1 回 = 1 操作)
//   - 'project-suggestion-refresh'  プロジェクト詳細での提案更新ボタン
//   - 'risk-creation-suggest'       リスク起票時のサジェスト
//   - 'auto-tag-extract'            プロジェクト保存時の自動タグ抽出 (Phase 1)
//   - 'embedding-backfill'          バックグラウンド一括 embedding 生成
//
// `costJpy` は当該呼び出しに「テナント側に発生した課金額」(Beginner: 0 = 無料、Expert: 10、Pro: 30)。
// 内部の Anthropic / Voyage AI API 実コストとは別概念で、本番運用では別系統の財務追跡で突合する。

model ApiCallLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  userId          String?  @map("user_id") @db.Uuid // cron / 匿名 / システム実行時は null
  featureUnit     String   @map("feature_unit") @db.VarChar(40)
  modelName       String   @map("model_name") @db.VarChar(60)
  /// LLM 入力トークン数 (Anthropic)。embedding 専用呼び出しは null。
  llmInputTokens  Int?     @map("llm_input_tokens")
  llmOutputTokens Int?     @map("llm_output_tokens")
  /// embedding トークン数 (Voyage AI)。LLM 専用呼び出しは null。
  embeddingTokens Int?     @map("embedding_tokens")
  /// テナント側に発生した課金額 (円整数)。
  costJpy         Int      @map("cost_jpy")
  latencyMs       Int      @map("latency_ms")
  requestId       String   @map("request_id") @db.VarChar(64)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation("ApiCallLogActor", fields: [userId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)], map: "idx_api_call_logs_tenant")
  @@index([requestId], map: "idx_api_call_logs_request")
  @@index([featureUnit, createdAt(sort: Desc)], map: "idx_api_call_logs_feature")
  @@map("api_call_logs")
}
