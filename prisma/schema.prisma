// たすきば Knowledge Relay - Prisma Schema
// 設計書: docs/design/DATA_MODEL.md / docs/design/SUGGESTION_ENGINE.md

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  // PR #4 (T-03 Phase 2): pgvector の vector 型を Prisma が認識できないため、
  // Unsupported("vector(1024)") として宣言。Prisma Client では `unknown` 型として扱われ、
  // 直接 read/write するには $queryRaw を使う。
  // 詳細: https://www.prisma.io/docs/orm/prisma-schema/data-model/unsupported-database-features
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  // PR #4 (T-03 Phase 2): pgvector 拡張を Prisma に明示。
  // migration では `CREATE EXTENSION IF NOT EXISTS vector;` を実行する。
  extensions = [vector]
}

// ============================================================
// Tenants (PR #2 / T-03 提案エンジン v2)
// ============================================================
//
// マルチテナント基盤。すべての業務エンティティの所属を一元管理する。
// v1 (2026-06-01) は default-tenant という単一テナントのみで稼働し、
// v1.x で UI を介したテナント追加を可能にする。
//
// 課金モデル (per-API-call、3 プラン構成):
//   - Beginner: 月間 100 回上限・最大 5 席・無料・Claude Haiku
//   - Expert:   無制限従量課金 (¥10/call)・Claude Haiku
//   - Pro:      無制限従量課金 (¥30/call)・Claude Sonnet
//
// 月初リセット: Vercel Cron が `lastResetAt < 当月初` のテナントの
// `currentMonthApiCallCount` / `currentMonthApiCostJpy` を 0 にリセット。
// 同 cron が `scheduledPlanChangeAt <= 当日` のテナントに対し
// `scheduledNextPlan` を `plan` に適用 (ダウングレード遅延適用)。
//
// 設計判断: tenantId は v1 では DB DEFAULT で default-tenant の UUID を注入し、
// 既存コードを変更せずに単一テナント運用を可能にする。v1.x で DEFAULT を外す。

model Tenant {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// URL ルーティング用 slug。v1 は 'default' 固定、v1.x で複数テナント対応時に動的解決。
  slug                     String    @unique @db.VarChar(60)
  name                     String    @db.VarChar(100)
  /// 'beginner' | 'expert' | 'pro'
  plan                     String    @default("beginner") @db.VarChar(20)
  currentMonthApiCallCount Int       @default(0) @map("current_month_api_call_count")
  currentMonthApiCostJpy   Int       @default(0) @map("current_month_api_cost_jpy")
  /// ユーザ自己設定の月次予算上限 (円)。NULL = 無制限。withMeteredLLM が予測コスト超過チェックで参照。
  monthlyBudgetCapJpy      Int?      @map("monthly_budget_cap_jpy")
  /// Beginner プランの月間 API 呼び出し回数上限 (default 100)。プラン契約変更時のみ書き換え。
  beginnerMonthlyCallLimit Int       @default(100) @map("beginner_monthly_call_limit")
  /// Beginner プランの最大席数 (default 5)。User.tenantId が同じカウントで判定。
  beginnerMaxSeats         Int       @default(5) @map("beginner_max_seats")
  pricePerCallHaiku        Int       @default(10) @map("price_per_call_haiku")
  pricePerCallSonnet       Int       @default(30) @map("price_per_call_sonnet")
  /// プラン変更予約: ダウングレード時のみ翌月適用 (Expert/Pro → Beginner)。
  scheduledPlanChangeAt    DateTime? @map("scheduled_plan_change_at") @db.Timestamptz
  scheduledNextPlan        String?   @map("scheduled_next_plan") @db.VarChar(20)
  /// 月初リセット cron が処理した最後の月初 (UTC ベース、毎月 1 日 00:00 UTC)。
  lastResetAt              DateTime? @map("last_reset_at") @db.Timestamptz
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                DateTime? @map("deleted_at") @db.Timestamptz

  // Relations: 13 業務エンティティ + ApiCallLog
  users           User[]
  customers       Customer[]
  projects        Project[]
  knowledges      Knowledge[]
  risksIssues     RiskIssue[]
  retrospectives  Retrospective[]
  memos           Memo[]
  stakeholders    Stakeholder[]
  comments        Comment[]
  mentions        Mention[]
  notifications   Notification[]
  attachments     Attachment[]
  systemErrorLogs SystemErrorLog[]
  apiCallLogs     ApiCallLog[]

  @@index([plan], map: "idx_tenants_plan")
  @@map("tenants")
}

// ============================================================
// Users & Authentication
// ============================================================

model User {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // PR #2 (T-03): マルチテナント基盤。v1 では DB DEFAULT で default-tenant に自動配属。
  // v1.x で UI 由来のテナント割当が必要になったタイミングで DEFAULT を外す。
  tenantId            String    @default(dbgenerated("'00000000-0000-0000-0000-000000000001'::uuid")) @map("tenant_id") @db.Uuid
  name                String    @db.VarChar(100)
  email               String    @db.VarChar(255)
  passwordHash        String    @map("password_hash") @db.VarChar(255)
  systemRole          String    @default("general") @map("system_role") @db.VarChar(20)
  isActive            Boolean   @default(true) @map("is_active")
  failedLoginCount    Int       @default(0) @map("failed_login_count")
  lockedUntil         DateTime? @map("locked_until") @db.Timestamptz
  // T-21 (2026-04-28): 一時ロック発生回数の累積カウンタ。
  //   permanentLock 発火経路の起点 (5.29 選択肢 A)。
  //   閾値到達 (PERMANENT_LOCK_THRESHOLD=3) で permanentLock=true にセット。
  //   ログイン成功時に 0 にリセット (一時ロックを乗り越えて成功した = 正規ユーザの可能性)。
  temporaryLockCount  Int       @default(0) @map("temporary_lock_count")
  permanentLock       Boolean   @default(false) @map("permanent_lock")
  mfaEnabled          Boolean   @default(false) @map("mfa_enabled")
  mfaSecretEncrypted  String?   @map("mfa_secret_encrypted") @db.VarChar(255)
  mfaEnabledAt        DateTime? @map("mfa_enabled_at") @db.Timestamptz
  // PR #116 (2026-04-24): MFA verify 総当たり対策。パスワードロックとは別系統。
  //   - 3 回連続失敗で 30 分ロック (mfaLockedUntil に解除時刻をセット)
  //   - 正しい TOTP or recovery code 入力で 0 にリセット
  //   - 恒久ロックは設けない (recovery code 経路で自己解除可能なため)
  mfaFailedCount      Int       @default(0) @map("mfa_failed_count")
  mfaLockedUntil      DateTime? @map("mfa_locked_until") @db.Timestamptz
  lastLoginAt         DateTime? @map("last_login_at") @db.Timestamptz
  forcePasswordChange Boolean   @default(false) @map("force_password_change")
  // PR #72: 画面テーマ設定。既定 'light' (ライトテーマ)。ユーザが明示的に変更した
  // 値がセッションをまたいで永続適用されるため、sessionStorage ではなく DB 永続化する。
  themePreference     String    @default("light") @map("theme_preference") @db.VarChar(30)
  // PR #118: 個別タイムゾーン (IANA 名、例 'Asia/Tokyo'/'America/New_York')。
  //   null の場合はシステムデフォルト (env APP_DEFAULT_TIMEZONE or config/i18n.ts) を使用。
  //   DB は常に UTC で格納し、描画時にこの値を Intl.DateTimeFormat に渡す方針。
  timezone            String?   @map("timezone") @db.VarChar(60)
  // PR #118: 個別ロケール (BCP 47、例 'ja-JP'/'en-US')。null はシステムデフォルト。
  locale              String?   @map("locale") @db.VarChar(10)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  projectMembers          ProjectMember[]          @relation("UserProjectMembers")
  assignedTasks           Task[]                   @relation("TaskAssignee")
  taskProgressLogs        TaskProgressLog[]        @relation("ProgressUpdater")
  reportedRisks           RiskIssue[]              @relation("RiskReporter")
  assignedRisks           RiskIssue[]              @relation("RiskAssignee")
  createdKnowledges       Knowledge[]              @relation("KnowledgeCreator")
  updatedKnowledges       Knowledge[]              @relation("KnowledgeUpdater")
  auditLogs               AuditLog[]
  authEventLogs           AuthEventLog[]
  systemErrorLogs         SystemErrorLog[]
  roleChangesPerformed    RoleChangeLog[]          @relation("RoleChanger")
  roleChangesReceived     RoleChangeLog[]          @relation("RoleTarget")
  sessions                Session[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  recoveryCodes           RecoveryCode[]
  passwordHistories       PasswordHistory[]
  addedAttachments        Attachment[]             @relation("AttachmentAddedBy")
  memos                   Memo[]                   @relation("MemoAuthor")
  stakeholderRecords      Stakeholder[]            @relation("StakeholderUser")
  authoredComments        Comment[]                @relation("CommentAuthor")
  notifications           Notification[]           @relation("NotificationRecipient")
  receivedMentions        Mention[]                @relation("MentionTarget")
  apiCallLogs             ApiCallLog[]             @relation("ApiCallLogActor")

  // PR #2: tenant への back relation
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([email], map: "idx_users_email")
  @@index([isActive, lastLoginAt], map: "idx_users_active")
  @@index([tenantId], map: "idx_users_tenant")
  @@map("users")
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionToken String   @unique @map("session_token") @db.VarChar(255)
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_sessions_user")
  @@map("sessions")
}

model EmailVerificationToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("password_reset_tokens")
}

model RecoveryCode {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  codeHash  String    @map("code_hash") @db.VarChar(255)
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("recovery_codes")
}

model PasswordHistory {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("password_histories")
}

// ============================================================
// Customers (PR #111)
// ============================================================
//
// 顧客管理。プロジェクトは必ず顧客に紐付く (1 顧客 : N プロジェクト)。
//
// 運用:
//   - システム管理者 (systemRole='admin') のみ CRUD 可能
//   - 物理削除方針 (論理削除列を持たない、Project とは別)
//   - 顧客削除 → 紐付く Project は既存 deleteProjectCascade で論理削除 (PR #111-2 で実装)
//   - 物理削除時の FK 整合性は Project.customer_id の ON DELETE SET NULL で担保
//     (論理削除済み Project も customer_id が dangling にならない)
//
// 設計方針: docs/developer/DESIGN.md の Customer 節参照 (PR #111-2 で追記)

model Customer {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // PR #2: tenant 配属 (DEFAULT default-tenant)
  tenantId      String   @default(dbgenerated("'00000000-0000-0000-0000-000000000001'::uuid")) @map("tenant_id") @db.Uuid
  name          String   @db.VarChar(100)
  department    String?  @db.VarChar(100)
  contactPerson String?  @map("contact_person") @db.VarChar(100)
  contactEmail  String?  @map("contact_email") @db.VarChar(255)
  notes         String?  @db.Text
  createdBy     String   @map("created_by") @db.Uuid
  updatedBy     String   @map("updated_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  projects Project[]

  @@index([name], map: "idx_customers_name")
  @@index([tenantId], map: "idx_customers_tenant")
  @@map("customers")
}

// ============================================================
// Projects
// ============================================================

model Project {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // PR #2: tenant 配属 (DEFAULT default-tenant)
  tenantId           String    @default(dbgenerated("'00000000-0000-0000-0000-000000000001'::uuid")) @map("tenant_id") @db.Uuid
  name               String    @db.VarChar(100)
  // PR #111-2: customer_name 列を廃止し Customer テーブルへの FK に完全移行。
  // ON DELETE SET NULL: Customer 物理削除時、論理削除済み Project (deletedAt != null) の
  // customer_id が dangling にならないよう明示的に null 化する。
  // アクティブな Project (deletedAt = null) を抱える Customer は削除不可、
  // もしくは deleteCustomerCascade で関連資源を一括カスケード削除してから削除する。
  // その結果 customerId は運用上 NOT NULL を保証できる。
  customerId         String    @map("customer_id") @db.Uuid
  customer           Customer  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  purpose            String    @db.Text
  background         String    @db.Text
  scope              String    @db.Text
  outOfScope         String?   @map("out_of_scope") @db.Text
  devMethod          String    @map("dev_method") @db.VarChar(30)
  // 項目 14 (PR-β): 契約形態 (準委任 / 請負 / SES / そのほか)。既存 Project は null 許容で後付け。
  contractType       String?   @map("contract_type") @db.VarChar(30)
  businessDomainTags Json      @default("[]") @map("business_domain_tags") @db.JsonB
  techStackTags      Json      @default("[]") @map("tech_stack_tags") @db.JsonB
  // PR #65: 新規プロジェクト作成時にナレッジ/過去課題を提案するため、
  // Knowledge と同じ粒度の工程タグも持たせる。Jaccard 類似度 + pg_trgm
  // テキスト類似度の併用で核心機能 (提案型サービス) を実現する。
  processTags        Json      @default("[]") @map("process_tags") @db.JsonB
  plannedStartDate   DateTime  @map("planned_start_date") @db.Date
  plannedEndDate     DateTime  @map("planned_end_date") @db.Date
  status             String    @default("planning") @db.VarChar(20)
  notes              String?   @db.Text
  // PR #4 (T-03 Phase 2): purpose / background / scope を結合した text の Voyage AI
  //   embedding (1024 次元、voyage-4-lite)。Cosine Similarity による意味検索の基盤。
  //   生成失敗時 NULL を許容 (本体 INSERT/UPDATE は成功させる fail-safe)。
  contentEmbedding   Unsupported("vector(1024)")? @map("content_embedding")
  createdBy          String    @map("created_by") @db.Uuid
  updatedBy          String    @map("updated_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  members           ProjectMember[]
  estimates         Estimate[]
  tasks             Task[]
  risksIssues       RiskIssue[]
  retrospectives    Retrospective[]
  knowledgeProjects KnowledgeProject[]
  stakeholders      Stakeholder[]

  @@index([status], map: "idx_projects_status")
  @@index([customerId], map: "idx_projects_customer_id")
  @@index([plannedStartDate, plannedEndDate], map: "idx_projects_dates")
  @@index([tenantId], map: "idx_projects_tenant")
  @@map("projects")
}

// ============================================================
// Estimates
// ============================================================

model Estimate {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId       String    @map("project_id") @db.Uuid
  itemName        String    @map("item_name") @db.VarChar(100)
  category        String    @db.VarChar(30)
  devMethod       String    @map("dev_method") @db.VarChar(30)
  estimatedEffort Decimal   @map("estimated_effort") @db.Decimal(10, 2)
  effortUnit      String    @map("effort_unit") @db.VarChar(20)
  rationale       String    @db.Text
  preconditions   String?   @db.Text
  isConfirmed     Boolean   @default(false) @map("is_confirmed")
  notes           String?   @db.Text
  createdBy       String    @map("created_by") @db.Uuid
  updatedBy       String    @map("updated_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId], map: "idx_estimates_project")
  @@map("estimates")
}

model ProjectMember {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  projectRole String   @map("project_role") @db.VarChar(20)
  assignedBy  String   @map("assigned_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation("UserProjectMembers", fields: [userId], references: [id])

  @@unique([projectId, userId], map: "uq_pm_project_user")
  @@index([projectId], map: "idx_pm_project")
  @@index([userId], map: "idx_pm_user")
  @@map("project_members")
}

// ============================================================
// Tasks / WBS
// ============================================================

model Task {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId        String    @map("project_id") @db.Uuid
  parentTaskId     String?   @map("parent_task_id") @db.Uuid
  type             String    @default("activity") @db.VarChar(20) // work_package | activity
  wbsNumber        String?   @map("wbs_number") @db.VarChar(50)
  name             String    @db.VarChar(100)
  description      String?   @db.Text
  category         String    @db.VarChar(30)
  assigneeId       String?   @map("assignee_id") @db.Uuid // WP は null、ACT は必須
  plannedStartDate DateTime? @map("planned_start_date") @db.Date // WP は子から自動計算
  plannedEndDate   DateTime? @map("planned_end_date") @db.Date // WP は子から自動計算
  actualStartDate  DateTime? @map("actual_start_date") @db.Date
  actualEndDate    DateTime? @map("actual_end_date") @db.Date
  plannedEffort    Decimal   @default(0) @map("planned_effort") @db.Decimal(10, 2) // WP は子の合計
  priority         String?   @default("medium") @db.VarChar(10)
  status           String    @default("not_started") @db.VarChar(20)
  progressRate     Int       @default(0) @map("progress_rate") // WP は子の加重平均
  isMilestone      Boolean   @default(false) @map("is_milestone")
  notes            String?   @db.Text
  createdBy        String    @map("created_by") @db.Uuid
  updatedBy        String    @map("updated_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  project        Project           @relation(fields: [projectId], references: [id])
  parentTask     Task?             @relation("TaskHierarchy", fields: [parentTaskId], references: [id])
  childTasks     Task[]            @relation("TaskHierarchy")
  assignee       User?             @relation("TaskAssignee", fields: [assigneeId], references: [id])
  progressLogs   TaskProgressLog[]
  taskKnowledges TaskKnowledge[]

  @@index([projectId], map: "idx_tasks_project")
  @@index([assigneeId, status], map: "idx_tasks_assignee")
  @@index([parentTaskId], map: "idx_tasks_parent")
  @@index([projectId, plannedStartDate, plannedEndDate], map: "idx_tasks_gantt")
  @@map("tasks")
}

model TaskProgressLog {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId          String    @map("task_id") @db.Uuid
  updatedBy       String    @map("updated_by") @db.Uuid
  updateDate      DateTime  @map("update_date") @db.Date
  progressRate    Int       @map("progress_rate")
  actualEffort    Decimal   @map("actual_effort") @db.Decimal(10, 2)
  remainingEffort Decimal?  @map("remaining_effort") @db.Decimal(10, 2)
  status          String    @db.VarChar(20)
  isDelayed       Boolean   @default(false) @map("is_delayed")
  delayReason     String?   @map("delay_reason") @db.Text
  workMemo        String?   @map("work_memo") @db.Text
  hasIssue        Boolean   @default(false) @map("has_issue")
  nextAction      String?   @map("next_action") @db.Text
  completedDate   DateTime? @map("completed_date") @db.Date
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  task    Task @relation(fields: [taskId], references: [id])
  updater User @relation("ProgressUpdater", fields: [updatedBy], references: [id])

  @@index([taskId, updateDate(sort: Desc)], map: "idx_progress_task")
  @@map("task_progress_logs")
}

// ============================================================
// Risks & Issues
// ============================================================

model RiskIssue {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // PR #2: tenant 配属 (DEFAULT default-tenant)
  tenantId       String    @default(dbgenerated("'00000000-0000-0000-0000-000000000001'::uuid")) @map("tenant_id") @db.Uuid
  projectId      String    @map("project_id") @db.Uuid
  type           String    @db.VarChar(10) // risk | issue
  title          String    @db.VarChar(100)
  content        String    @db.Text
  cause          String?   @db.Text
  impact         String    @db.VarChar(10) // low | medium | high
  likelihood     String?   @db.VarChar(10)
  priority       String    @db.VarChar(10) // low | medium | high
  responsePolicy String?   @map("response_policy") @db.Text
  responseDetail String?   @map("response_detail") @db.Text
  reporterId     String    @map("reporter_id") @db.Uuid
  assigneeId     String?   @map("assignee_id") @db.Uuid
  deadline       DateTime? @db.Date
  state          String    @default("open") @db.VarChar(20)
  result         String?   @db.Text
  lessonLearned  String?   @map("lesson_learned") @db.Text
  visibility     String    @default("draft") @db.VarChar(20) // draft | public (PR #60)
  riskNature     String?   @map("risk_nature") @db.VarChar(20) // threat | opportunity (type=risk のみ)
  // PR #4 (T-03 Phase 2): title + content + cause + lessonLearned 等を結合した text の embedding
  contentEmbedding Unsupported("vector(1024)")? @map("content_embedding")
  createdBy      String    @map("created_by") @db.Uuid
  updatedBy      String    @map("updated_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  project  Project @relation(fields: [projectId], references: [id])
  reporter User    @relation("RiskReporter", fields: [reporterId], references: [id])
  assignee User?   @relation("RiskAssignee", fields: [assigneeId], references: [id])

  @@index([projectId, type], map: "idx_risks_project")
  @@index([state, priority], map: "idx_risks_state")
  @@index([assigneeId], map: "idx_risks_assignee")
  @@index([tenantId], map: "idx_risks_tenant")
  @@map("risks_issues")
}

// ============================================================
// Stakeholder Management (PMBOK 13)
// feat/stakeholder-management:
//   プロジェクトに関与する全関係者を管理する。Mendelow Power/Interest grid (1-5 段階) +
//   姿勢 (賛成/中立/反対) + Engagement Gap (現在 vs 望ましい) の PMBOK 準拠フル仕様。
//   userId は内部メンバー用 (nullable)。null なら外部関係者 (顧客役員、規制機関等)。
//   可視性は service 層で PM/TL + admin に限定 (人物評を含むため)。
// ============================================================

model Stakeholder {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // PR #2: tenant 配属 (DEFAULT default-tenant)
  tenantId          String    @default(dbgenerated("'00000000-0000-0000-0000-000000000001'::uuid")) @map("tenant_id") @db.Uuid
  projectId         String    @map("project_id") @db.Uuid
  // 内部メンバーとの紐付け (任意)。null なら外部関係者。
  // ON DELETE SET NULL: User 物理削除時にステークホルダー記録は残す (人物評・履歴の保全)。
  userId            String?   @map("user_id") @db.Uuid
  // 表示用氏名: 内部紐付け時も独立した列を持つ (User.name とは別の通称・敬称付き表記を許容)
  name              String    @db.VarChar(100)
  organization      String?   @db.VarChar(100) // 所属組織 (例: 顧客企画部、規制機関名)
  role              String?   @db.VarChar(100) // 役職 (例: 部長、CTO)
  contactInfo       String?   @map("contact_info") @db.Text // 連絡先メモ
  // PMBOK Power/Interest grid: 1-5 段階で格納 (UI 4 象限分類は閾値 >= 4 で計算)
  influence         Int       @db.SmallInt // 影響度 1=最低 / 5=最高
  interest          Int       @db.SmallInt // 関心度 1=最低 / 5=最高
  // 姿勢 (賛成/中立/反対): 同じ象限でも対応戦略が変わるため
  attitude          String    @db.VarChar(20) // supportive | neutral | opposing
  // PMBOK 13.1.2 Engagement Assessment Matrix (5 段階)
  currentEngagement String    @map("current_engagement") @db.VarChar(20) // unaware|resistant|neutral|supportive|leading
  desiredEngagement String    @map("desired_engagement") @db.VarChar(20)
  // Phase D 要件 11/12 (2026-04-28): Power/Interest grid から自動分類する優先度
  // (high|medium|low)。サービス層で influence × interest から deriveStakeholderPriority
  // により計算してから保存する。一覧の sort/filter UI で利用。
  priority          String    @default("medium") @db.VarChar(10)
  // 自由記述: 人となり / 考え方 / 接し方のコツ
  personality       String?   @db.Text
  // 検索/分類タグ (例: ["技術志向", "数字派"])
  tags              Json      @default("[]") @db.JsonB
  // 戦略・対応方針 (具体的アクション)
  strategy          String?   @db.Text
  createdBy         String    @map("created_by") @db.Uuid
  updatedBy         String    @map("updated_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  project Project @relation(fields: [projectId], references: [id])
  user    User?   @relation("StakeholderUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId], map: "idx_stakeholders_project")
  @@index([userId], map: "idx_stakeholders_user")
  // Phase D 要件 12: 優先度フィルタの絞り込みに利用
  @@index([priority], map: "idx_stakeholders_priority")
  @@index([tenantId], map: "idx_stakeholders_tenant")
  @@map("stakeholders")
}

// ============================================================
// Knowledge
// ============================================================

model Knowledge {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // PR #2: tenant 配属 (DEFAULT default-tenant)
  // テナント独立性を担保するため Knowledge はテナント間で重複コピー (default-tenant の
  // シードナレッジを新規テナントに seedTenant() で複製)。設計判断は SUGGESTION_ENGINE_PLAN.md PR #6 参照。
  tenantId           String    @default(dbgenerated("'00000000-0000-0000-0000-000000000001'::uuid")) @map("tenant_id") @db.Uuid
  title              String    @db.VarChar(150)
  knowledgeType      String    @map("knowledge_type") @db.VarChar(30)
  background         String    @db.Text
  content            String    @db.Text
  result             String    @db.Text
  conclusion         String?   @db.Text
  recommendation     String?   @db.Text
  reusability        String?   @db.VarChar(10)
  techTags           Json      @default("[]") @map("tech_tags") @db.JsonB
  devMethod          String?   @map("dev_method") @db.VarChar(30)
  processTags        Json      @default("[]") @map("process_tags") @db.JsonB
  // PR #65 Phase 2 (b): Project.businessDomainTags との対称化。
  // 提案型サービスの Jaccard 類似度で業務ドメイン軸もマッチできるようにする。
  businessDomainTags Json      @default("[]") @map("business_domain_tags") @db.JsonB
  visibility         String    @default("draft") @db.VarChar(20) // draft | project | company
  // PR #4 (T-03 Phase 2): title + background + content + result + conclusion を結合した text の embedding
  contentEmbedding   Unsupported("vector(1024)")? @map("content_embedding")
  createdBy          String    @map("created_by") @db.Uuid
  updatedBy          String    @map("updated_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  creator           User               @relation("KnowledgeCreator", fields: [createdBy], references: [id])
  updater           User               @relation("KnowledgeUpdater", fields: [updatedBy], references: [id])
  knowledgeProjects KnowledgeProject[]
  taskKnowledges    TaskKnowledge[]

  @@index([knowledgeType], map: "idx_knowledges_type")
  @@index([visibility], map: "idx_knowledges_visibility")
  @@index([tenantId], map: "idx_knowledges_tenant")
  @@map("knowledges")
}

model KnowledgeProject {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  knowledgeId String @map("knowledge_id") @db.Uuid
  projectId   String @map("project_id") @db.Uuid

  knowledge Knowledge @relation(fields: [knowledgeId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])

  @@unique([knowledgeId, projectId])
  @@map("knowledge_projects")
}

model TaskKnowledge {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId      String @map("task_id") @db.Uuid
  knowledgeId String @map("knowledge_id") @db.Uuid

  task      Task      @relation(fields: [taskId], references: [id])
  knowledge Knowledge @relation(fields: [knowledgeId], references: [id])

  @@unique([taskId, knowledgeId])
  @@map("task_knowledges")
}

